# .env.example — Copy this file to .env and fill in your values
# Never commit your actual .env file to version control!

# ── Telegram Bot Token ─────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
# Steps: Open Telegram → Search @BotFather → /newbot → Follow prompts
BOT_TOKEN=your_bot_token_here

# ── Admin User IDs ─────────────────────────────────────────────────────────────
# Telegram user IDs allowed to control the bot (comma-separated)
# To find your ID: message @userinfobot on Telegram
ADMIN_IDS=123456789,987654321

# ── Target Chat ID ─────────────────────────────────────────────────────────────
# Where the bot will SEND its scheduled messages.
# Options:
#   - Your personal chat ID (same as your user ID, e.g. 123456789)
#   - A group chat ID (negative number, e.g. -987654321)
#   - A channel ID (e.g. -1001234567890)
# Note: For groups/channels, add the bot as an admin first!
TARGET_CHAT_ID=123456789
